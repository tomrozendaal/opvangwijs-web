---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import Footer from '../components/Footer.astro';
import { CONTACT_EMAIL, DOWNLOAD_MACOS, DOWNLOAD_WINDOWS } from '../lib/config.ts';
import { withBase } from '../lib/url.ts';
---

<Layout
  title="Bedankt voor je aankoop — Opvangwijs"
  description="Bedankt voor je aankoop van Opvangwijs. Download de app hieronder voor macOS of Windows."
  noindex={true}
>
  <header class="sticky top-0 z-50 w-full border-b border-border bg-background/85 backdrop-blur-md">
    <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
      <a href={withBase('')} class="flex items-center gap-3">
        <Logo size={36} />
        <span class="text-lg font-semibold tracking-tight text-foreground">Opvangwijs</span>
      </a>
    </div>
  </header>

  <main class="mx-auto max-w-2xl px-6 py-16 text-center sm:py-24">
    <div
      class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 text-primary"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M20 6 9 17l-5-5" />
      </svg>
    </div>

    <h1 class="mt-6 text-3xl font-semibold text-foreground sm:text-4xl">
      Bedankt voor je aankoop!
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-muted-foreground">
      Je betaling is gelukt. Download Opvangwijs hieronder en installeer de app op je eigen
      computer. Bewaar deze pagina of de downloadlink, dan kun je later opnieuw downloaden.
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href={DOWNLOAD_MACOS}
        class="inline-flex h-12 w-full items-center justify-center gap-2 rounded-md bg-primary px-6 text-base font-medium text-primary-foreground shadow-sm transition-opacity hover:opacity-90 sm:w-auto"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M16.365 1.43c0 1.14-.42 2.21-1.13 3.02-.78.91-2.05 1.61-3.18 1.52-.13-1.1.42-2.27 1.1-3.02.77-.86 2.13-1.5 3.21-1.52zM20.5 17.4c-.55 1.27-.82 1.83-1.53 2.95-.99 1.56-2.39 3.51-4.12 3.52-1.54.02-1.93-1-4.02-.99-2.09.01-2.52 1.01-4.06.99-1.73-.02-3.06-1.78-4.05-3.34C-.06 16.96-.45 11.9 1.27 9.21c1.16-1.83 2.99-2.9 4.71-2.9 1.75 0 2.85 1 4.3 1 1.4 0 2.26-1 4.29-1 1.53 0 3.15.84 4.31 2.28-3.79 2.08-3.17 7.49 1.62 8.81z"
          />
        </svg>
        Download voor macOS
      </a>
      <a
        href={DOWNLOAD_WINDOWS}
        class="inline-flex h-12 w-full items-center justify-center gap-2 rounded-md border border-border bg-background px-6 text-base font-medium text-foreground transition-colors hover:bg-secondary sm:w-auto"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M3 5.1 10.5 4v7.5H3V5.1zM10.5 12.5V20L3 18.9v-6.4h7.5zM11.5 3.85 21 2.5v9h-9.5V3.85zM21 12.5v9l-9.5-1.35V12.5H21z" />
        </svg>
        Download voor Windows
      </a>
    </div>

    <div class="mt-12 rounded-lg border border-border bg-card px-6 py-5 text-left text-sm text-muted-foreground">
      <p>
        Open na het downloaden het installatiebestand en volg de stappen. Al je gegevens blijven
        lokaal op je eigen computer. Maak via <strong class="font-semibold text-foreground"
          >"Back-up exporteren"</strong
        > regelmatig een reservekopie.
      </p>
      <p class="mt-3">
        Lukt het downloaden of installeren niet? Mail ons op
        <a
          href={`mailto:${CONTACT_EMAIL}`}
          class="font-medium text-primary underline underline-offset-2">{CONTACT_EMAIL}</a
        > — we helpen je graag verder.
      </p>
    </div>

    <a
      href={withBase('')}
      class="mt-10 inline-block text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      ← Terug naar home
    </a>
  </main>

  <Footer />
</Layout>
