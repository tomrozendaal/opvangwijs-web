---
import Layout from './Layout.astro';
import Logo from '../components/Logo.astro';
import Footer from '../components/Footer.astro';
import { BUY_URL, PRICE_LABEL } from '../lib/config.ts';
import { withBase } from '../lib/url.ts';

interface Props {
  title: string;
  description: string;
  updated: string;
}

const { title, description, updated } = Astro.props;
---

<Layout title={`${title} — Opvangwijs`} description={description}>
  <header class="sticky top-0 z-50 w-full border-b border-border bg-background/85 backdrop-blur-md">
    <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
      <a href={withBase('')} class="flex items-center gap-3">
        <Logo size={36} />
        <span class="text-lg font-semibold tracking-tight text-foreground">Opvangwijs</span>
      </a>

      <a
        href={BUY_URL}
        class="inline-flex h-10 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-sm transition-opacity hover:opacity-90"
      >
        Koop voor {PRICE_LABEL}
      </a>
    </div>
  </header>

  <main class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <a
      href={withBase('')}
      class="text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      ← Terug naar home
    </a>

    <h1 class="mt-6 text-3xl font-semibold text-foreground sm:text-4xl">{title}</h1>
    <p class="mt-3 text-sm text-muted-foreground">Laatst bijgewerkt: {updated}</p>

    <div
      class="legal mt-10 space-y-6 text-base leading-relaxed text-muted-foreground [&_a]:font-medium [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-2 [&_h2]:mt-10 [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-foreground [&_li]:ml-1 [&_strong]:font-semibold [&_strong]:text-foreground [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-6"
    >
      <slot />
    </div>
  </main>

  <Footer />
</Layout>
