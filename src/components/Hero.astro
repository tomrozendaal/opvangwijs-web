---
import { BUY_URL, PRICE_LABEL } from '../lib/config.ts';
---

<section id="top" class="relative overflow-hidden">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,hsl(150_18%_94%),transparent_70%)]"
  >
  </div>

  <div class="relative mx-auto max-w-4xl px-6 pt-20 pb-16 text-center sm:pt-28 sm:pb-24">
    <span
      class="mb-6 inline-flex items-center rounded-full border border-border bg-secondary/60 px-3 py-1 text-xs font-medium text-secondary-foreground"
    >
      Voor Nederlandse gastouders
    </span>

    <h1 class="text-4xl font-semibold text-foreground sm:text-5xl md:text-6xl">
      Eenvoudige administratie voor jouw <span class="text-primary">gastouderopvang</span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground sm:text-xl">
      Opvangwijs houdt je kinderen, kalender en inkomsten overzichtelijk bij — lokaal op je eigen
      computer, in het Nederlands, en eenmalig betalen.
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href={BUY_URL}
        class="inline-flex h-12 items-center rounded-md bg-primary px-6 text-base font-medium text-primary-foreground shadow-sm transition-opacity hover:opacity-90"
      >
        Koop voor {PRICE_LABEL}
      </a>
      <a
        href="#schermen"
        class="inline-flex h-12 items-center rounded-md border border-border bg-background px-6 text-base font-medium text-foreground transition-colors hover:bg-secondary"
      >
        Bekijk de functies
      </a>
    </div>

    <ul
      class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-muted-foreground"
    >
      <li class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-primary"></span> Lokaal en privé
      </li>
      <li class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-primary"></span> Geen account
      </li>
      <li class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-primary"></span> Eenmalig {PRICE_LABEL}
      </li>
    </ul>
  </div>
</section>
