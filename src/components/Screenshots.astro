---
import { withBase } from '../lib/url.ts';

const shots = [
  {
    src: withBase('screenshots/kinderen.png'),
    alt: 'Opvangwijs scherm Kinderen — overzicht van alle kinderen in de opvang',
    title: 'Alle kinderen in één overzicht',
    body:
      'Beheer naam, leeftijd, dagen en contracten van elk kind. De gratis-eigen-kinderen tellen vanzelf mee in je ratio.',
  },
  {
    src: withBase('screenshots/kind-detail.png'),
    alt: 'Opvangwijs scherm Kind — detailpagina met contracten van een kind',
    title: 'Per kind alle contracten bij elkaar',
    body:
      'Open een kind en zie in één oogopslag de gegevens, de opvangdagen en alle contracten — actief en afgelopen.',
  },
  {
    src: withBase('screenshots/kalender.png'),
    alt: 'Opvangwijs scherm Kalender — kinderen per dag van de week',
    title: 'Per dag direct zien wie er is',
    body:
      'Een rustige weekkalender met je vaste kinderen, extra dagen en de aantallen per dag. Klik op een dag voor de details.',
  },
  {
    src: withBase('screenshots/vakantie.png'),
    alt: 'Opvangwijs scherm Vakantie — vakanties van jou en de kinderen',
    title: 'Vakanties van jou en de kinderen',
    body:
      'Leg vast wanneer je zelf vrij bent en wanneer een kind op vakantie is. De inkomsten houden er automatisch rekening mee.',
  },
  {
    src: withBase('screenshots/inkomsten.png'),
    alt: 'Opvangwijs scherm Inkomsten — maandoverzicht van inkomsten per kind',
    title: 'Maandinkomsten automatisch berekend',
    body:
      'Per maand zie je dagen, uren, tarief en inkomsten per kind — opgeteld op basis van je kalender. Geen rekenwerk meer.',
  },
  {
    src: withBase('screenshots/instellingen.png'),
    alt: 'Opvangwijs scherm Instellingen — back-up exporteren en importeren',
    title: 'Je gegevens veilig in eigen beheer',
    body:
      'Alles blijft lokaal op je eigen computer. Exporteer met één klik een back-up of zet een eerdere terug.',
  },
];
---

<section id="schermen" class="bg-muted/40 py-20 sm:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-semibold text-foreground sm:text-4xl">Wat je krijgt</h2>
      <p class="mt-4 text-lg text-muted-foreground">
        De schermen waar je dagelijks mee werkt — van kinderen en kalender tot
        inkomsten, vakantieplanning en back-ups.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        shots.map((s) => (
          <figure class="overflow-hidden rounded-lg border border-border bg-card shadow-sm">
            <div class="border-b border-border bg-background">
              <img
                src={s.src}
                alt={s.alt}
                width="2000"
                height="1100"
                loading="lazy"
                class="block h-auto w-full"
              />
            </div>
            <figcaption class="px-6 py-5">
              <h3 class="text-base font-semibold text-foreground">{s.title}</h3>
              <p class="mt-1.5 text-sm text-muted-foreground">{s.body}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
