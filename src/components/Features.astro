---
const features = [
  {
    title: 'Lokaal en privé',
    body: 'Alle gegevens blijven op je eigen computer. Geen cloud, geen account, geen internetverbinding nodig.',
    icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  },
  {
    title: 'In het Nederlands',
    body: 'Labels, knoppen, datums en foutmeldingen — alles in vertrouwde Nederlandse termen.',
    icon: 'M5 8h14M5 12h14M5 16h9',
  },
  {
    title: 'Eenvoudig overdraagbaar',
    body: 'Eén back-upbestand om mee te nemen naar een andere computer. Importeren en doorgaan.',
    icon: 'M12 3v12m0 0l-4-4m4 4l4-4M5 21h14',
  },
  {
    title: 'Eenmalig betalen',
    body: 'Geen abonnement. Je betaalt één keer €9,99 en kunt de app blijven gebruiken.',
    icon: 'M12 8v8m-4-4h8M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<section id="functies" class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-semibold text-foreground sm:text-4xl">
      Speciaal gemaakt voor gastouders
    </h2>
    <p class="mt-4 text-lg text-muted-foreground">
      Geen ruis, geen overbodige functies. Alleen wat je nodig hebt om je opvang draaiende te houden.
    </p>
  </div>

  <div class="mt-14 grid grid-cols-1 gap-5 sm:grid-cols-2">
    {
      features.map((f) => (
        <div class="rounded-lg border border-border bg-card p-6 shadow-sm">
          <div class="flex h-10 w-10 items-center justify-center rounded-md bg-secondary text-primary">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d={f.icon} />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-semibold text-foreground">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{f.body}</p>
        </div>
      ))
    }
  </div>
</section>
