---
import { BUY_URL, PRICE_LABEL } from '../lib/config.ts';
---

<section class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
  <div
    class="overflow-hidden rounded-lg bg-primary px-8 py-14 text-center text-primary-foreground sm:px-12"
  >
    <h2 class="text-3xl font-semibold sm:text-4xl">Klaar om je administratie eenvoudiger te maken?</h2>
    <p class="mx-auto mt-4 max-w-xl text-base opacity-90 sm:text-lg">
      Eenmalig {PRICE_LABEL}. Download direct, gebruik op je eigen computer, geen abonnement.
    </p>
    <a
      href={BUY_URL}
      class="mt-8 inline-flex h-12 items-center rounded-md bg-background px-6 text-base font-medium text-foreground shadow-sm transition-opacity hover:opacity-90"
    >
      Koop Opvangwijs voor {PRICE_LABEL}
    </a>
  </div>
</section>
