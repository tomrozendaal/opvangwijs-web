---
import Logo from './Logo.astro';
import { CONTACT_EMAIL } from '../lib/config.ts';
import { withBase } from '../lib/url.ts';

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-background">
  <div
    class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-6 px-6 py-10 sm:flex-row sm:items-center"
  >
    <div class="flex items-center gap-3">
      <Logo size={28} />
      <span class="text-sm font-medium text-foreground">Opvangwijs</span>
    </div>

    <nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-muted-foreground">
      <a href={`mailto:${CONTACT_EMAIL}`} class="transition-colors hover:text-foreground">
        {CONTACT_EMAIL}
      </a>
      <a href={withBase('privacy')} class="transition-colors hover:text-foreground">Privacy</a>
      <a href={withBase('voorwaarden')} class="transition-colors hover:text-foreground">Voorwaarden</a>
    </nav>

    <p class="text-sm text-muted-foreground">© {year} Opvangwijs</p>
  </div>
</footer>
