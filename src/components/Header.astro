---
import Logo from './Logo.astro';
import { BUY_URL, PRICE_LABEL } from '../lib/config.ts';
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-background/85 backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href="#top" class="flex items-center gap-3">
      <Logo size={36} />
      <span class="text-lg font-semibold tracking-tight text-foreground">Opvangwijs</span>
    </a>

    <nav class="hidden items-center gap-8 text-sm text-muted-foreground md:flex">
      <a href="#functies" class="transition-colors hover:text-foreground">Functies</a>
      <a href="#schermen" class="transition-colors hover:text-foreground">Schermen</a>
      <a href="#faq" class="transition-colors hover:text-foreground">Veelgestelde vragen</a>
    </nav>

    <a
      href={BUY_URL}
      class="inline-flex h-10 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-sm transition-opacity hover:opacity-90"
    >
      Koop voor {PRICE_LABEL}
    </a>
  </div>
</header>
